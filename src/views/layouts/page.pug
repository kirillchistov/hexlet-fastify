doctype html
html(lang='ru')
  head
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    title= title ? `${title} — Hexlet Fastify` : 'Hexlet Fastify'
    style.
      :root {
        --bg: #0f1117;
        --surface: #1a1d29;
        --surface-hover: #22263a;
        --text: #e8eaed;
        --muted: #9aa0a6;
        --accent: #2cb67d;
        --accent-hover: #25a06c;
        --border: rgba(255, 255, 255, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        line-height: 1.6;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.2s ease;
      }

      a:hover {
        color: var(--accent-hover);
      }

      .site-header {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 1rem 2rem;
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .site-nav {
        max-width: 960px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .site-logo {
        color: var(--accent);
        font-weight: 700;
        font-size: 1.25rem;
        letter-spacing: -0.02em;
      }

      .site-menu {
        list-style: none;
        display: flex;
        gap: 1.5rem;
        margin: 0;
        padding: 0;
      }

      .site-menu a {
        color: var(--text);
        font-weight: 500;
      }

      .site-menu a:hover {
        color: var(--accent);
      }

      .site-main {
        flex: 1;
        max-width: 960px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
        width: 100%;
      }

      .page-title {
        margin: 0 0 1rem;
        font-size: 2rem;
        letter-spacing: -0.03em;
      }

      .lead {
        color: var(--muted);
        font-size: 1.125rem;
        margin-bottom: 2rem;
      }

      .button {
        display: inline-block;
        background: var(--accent);
        color: var(--bg);
        font-weight: 600;
        padding: 0.75rem 1.25rem;
        border-radius: 8px;
      }

      .button:hover {
        background: var(--accent-hover);
        color: var(--bg);
      }

      .course-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 1rem;
      }

      .course-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        transition: border-color 0.2s ease, transform 0.2s ease;
      }

      .course-card:hover {
        border-color: var(--accent);
        transform: translateY(-2px);
      }

      .course-card a {
        display: block;
        padding: 1.25rem 1.5rem;
        color: inherit;
      }

      .course-card h2 {
        margin: 0 0 0.5rem;
        font-size: 1.125rem;
      }

      .course-card p {
        margin: 0;
        color: var(--muted);
      }

      .back-link {
        display: inline-block;
        margin-bottom: 1.5rem;
        color: var(--muted);
      }

      .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.5rem;
      }

      .page-header .page-title {
        margin-bottom: 0;
      }

      .form-card,
      .search-form {
        display: grid;
        gap: 1rem;
        margin-bottom: 2rem;
        padding: 1.25rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
      }

      .search-field {
        display: grid;
        gap: 0.5rem;
      }

      .search-field span {
        color: var(--muted);
        font-size: 0.875rem;
      }

      .form-field {
        display: grid;
        gap: 0.5rem;
      }

      .form-field label {
        color: var(--muted);
        font-size: 0.875rem;
      }

      .form-card input[type='text'],
      .form-card input[type='email'],
      .form-card input[type='password'],
      .form-card textarea,
      .search-form input[type='search'] {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--bg);
        color: var(--text);
      }

      .form-submit,
      .search-submit {
        justify-self: start;
        background: var(--accent);
        color: var(--bg);
        border: 0;
        border-radius: 8px;
        padding: 0.75rem 1.25rem;
        font-weight: 600;
        cursor: pointer;
      }

      .form-submit:hover,
      .search-submit:hover {
        background: var(--accent-hover);
      }

      .user-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 1rem;
      }

      .user-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
      }

      .user-card h2 {
        margin: 0 0 0.5rem;
        font-size: 1.125rem;
      }

      .user-card p {
        margin: 0;
        color: var(--muted);
      }

      .site-footer {
        background: var(--surface);
        border-top: 1px solid var(--border);
        padding: 1.5rem 2rem;
        text-align: center;
        color: var(--muted);
      }

      .site-footer p {
        margin: 0;
      }

  body
    include header
    main.site-main
      block content
    include footer
